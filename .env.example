# ═══════════════════════════════════════════════════════════════
# ReceiptVault AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Firebase Admin SDK ─────────────────────────────────────────
# Go to Firebase Console → Project Settings → Service Accounts
# → Generate new private key → Download JSON
# Paste the ENTIRE JSON as a single-line base64 string:
#   macOS/Linux:  base64 -i serviceAccount.json | tr -d '\n'
#   Windows:      [Convert]::ToBase64String([IO.File]::ReadAllBytes('serviceAccount.json'))
FIREBASE_SERVICE_ACCOUNT_BASE64=PASTE_BASE64_ENCODED_SERVICE_ACCOUNT_JSON_HERE

# Alternatively supply individual fields (only needed if not using base64 above):
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Stripe ─────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_PASTE_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# Webhook secret — from: stripe listen --forward-to localhost:3001/api/stripe/webhook
# Or from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_PASTE_YOUR_WEBHOOK_SIGNING_SECRET_HERE

# Stripe Price IDs — create in Stripe Dashboard → Products
# Products → Add product → Add price (recurring monthly)
STRIPE_PRICE_PLUS=price_PASTE_YOUR_PLUS_PRICE_ID_HERE
STRIPE_PRICE_PRO=price_PASTE_YOUR_PRO_PRICE_ID_HERE

# ─── Server ─────────────────────────────────────────────────────
PORT=3001

# Your frontend origin — no trailing slash
# Local dev:    http://localhost:5500
# Production:   https://yourapp.com
CLIENT_ORIGIN=http://localhost:5500
